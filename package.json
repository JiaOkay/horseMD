{
  "name": "horse",
  "version": "0.1.8",
  "description": "HorseMD Markdown Editor",
  "author": "mini_md",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BND-1/horseMD.git"
  },
  "homepage": "https://github.com/BND-1/horseMD#readme",
  "bugs": {
    "url": "https://github.com/BND-1/horseMD/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.6.5",
    "chokidar": "^4.0.3",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.horsemd.app",
    "productName": "HorseMD",
    "files": [
      "out/**/*"
    ],
    "icon": "build/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "BND-1",
        "repo": "horseMD"
      }
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor",
          "icon": "build/icon.ico"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor",
          "icon": "build/icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer.nsh"
    }
  }
}
