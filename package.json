{
  "name": "horse",
  "version": "0.5.5",
  "description": "HorseMD Markdown Editor",
  "author": "mini_md",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BND-1/horseMD.git"
  },
  "homepage": "https://github.com/BND-1/horseMD#readme",
  "bugs": {
    "url": "https://github.com/BND-1/horseMD/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "build:mobile": "vite build --config vite.mobile.config.mjs",
    "test:source-map": "node scripts/test-editor-source-map.mjs",
    "test:review": "node scripts/review-markup.test.mjs",
    "test:security": "node scripts/test-main-security.mjs && node scripts/test-pdf-document.mjs",
    "test:filesystem": "node scripts/test-main-filesystem.mjs",
    "test:watchers": "node scripts/test-main-watchers.mjs",
    "test:criticmarkup": "node scripts/test-strike-guard.mjs && node scripts/test-substitution-headless.mjs",
    "test:core": "npm run test:security && npm run test:filesystem && npm run test:watchers && npm run test:source-map && npm run test:review && npm run test:criticmarkup",
    "cap:sync": "npm run build:mobile && cap sync",
    "cap:ios": "npm run build:mobile && cap sync ios && cap open ios",
    "cap:android": "npm run build:mobile && cap sync android && cap open android",
    "dist:android": "npm run build:mobile && cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@milkdown/crepe": "^7.6.5",
    "chokidar": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "pinyin-pro": "^3.28.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.horsemd.app",
    "productName": "HorseMD",
    "files": [
      "out/**/*"
    ],
    "icon": "build/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "BND-1",
        "repo": "horseMD"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown Document",
          "role": "Editor",
          "icon": "build/icon.ico"
        },
        {
          "ext": "markdown",
          "name": "Markdown Document",
          "role": "Editor",
          "icon": "build/icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer.nsh"
    }
  }
}
